# Copy to discord-bot/.env and fill in (never commit .env)

# From Discord Developer Portal → Bot → Token
DISCORD_BOT_TOKEN=your_discord_bot_token

# Your guild server ID (Developer Mode → right-click server → Copy Server ID)
DISCORD_GUILD_ID=your_discord_guild_id

# Optional: channel ID for automatic check-in when a draft is created on the website
# Developer Mode → right-click #auction-checkin → Copy Channel ID
DISCORD_CHECKIN_CHANNEL_ID=

# Channel for designated + normal bidder announcements (separate from check-in)
# Developer Mode → right-click #auction-board → Copy Channel ID
DISCORD_BOARD_CHANNEL_ID=1499266177178800219

# Optional: Discord role ID allowed to run /start-checkin and /stop-checkin
# Leave empty to allow anyone with Manage Server permission
DISCORD_OFFICER_ROLE_ID=

# From Supabase → Settings → API → Project URL
SUPABASE_URL=your_supabase_project_url

# From Supabase → Settings → API → Secret key (service role — NOT the publishable key)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Emoji used for check-in reactions (default ✅)
CHECKIN_EMOJI=✅
